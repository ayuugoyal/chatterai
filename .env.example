# Database
DATABASE_URL=""

# App
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# AI Providers (Platform keys - agents can optionally provide their own)
GOOGLE_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Stripe (Optional - for payments)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email Configuration (Required for email verification and password reset)
# For Gmail: Use smtp.gmail.com, port 587, and App Password (not regular password)
# For other providers: Check their SMTP settings
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM_NAME="Chatter AI"
EMAIL_FROM_ADDRESS="your-email@gmail.com"