# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# PostgreSQL database connection string (required)
# Example: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=""

# ==============================================
# APPLICATION SETTINGS
# ==============================================
# Base URL for the application (required)
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Node environment (automatically set by Next.js)
# Values: development, production, test
NODE_ENV="development"

# ==============================================
# AI PROVIDER API KEYS
# ==============================================
# Platform-level API keys for AI providers
# Note: Individual agents can optionally provide their own API keys
# which will override these platform keys

# Google Gemini API Key (recommended: gemini-2.5-flash-lite)
GOOGLE_API_KEY=""

# Anthropic Claude API Key (model: claude-3-5-sonnet-20241022)
ANTHROPIC_API_KEY=""

# OpenAI API Key (model: gpt-4o-mini)
OPENAI_API_KEY=""

# ==============================================
# RAZORPAY PAYMENT GATEWAY (ACTIVE)
# ==============================================
# Razorpay is the active payment provider for subscriptions
# Get your keys from: https://dashboard.razorpay.com/app/website-app-settings/api-keys

# Server-side Razorpay Key ID (required for creating orders)
RAZORPAY_KEY_ID=""

# Server-side Razorpay Key Secret (required for verifying payments)
RAZORPAY_KEY_SECRET=""

# Client-side Razorpay Key ID (required for Checkout.js)
# This should be the same as RAZORPAY_KEY_ID but exposed to the browser
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Webhook Secret for verifying Razorpay webhook signatures
# Generate this in Razorpay Dashboard > Webhooks section
RAZORPAY_WEBHOOK_SECRET=""

# ==============================================
# STRIPE (DEPRECATED - NOT IN USE)
# ==============================================
# Stripe integration is prepared but not currently active
# The project uses Razorpay instead
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# ==============================================
# GOOGLE OAUTH (OPTIONAL)
# ==============================================
# Optional Google OAuth for social sign-in
# Get credentials from: https://console.cloud.google.com/apis/credentials

# Google OAuth Client ID
GOOGLE_CLIENT_ID=""

# Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=""

# Google OAuth Redirect URI
# Development: http://localhost:3000/api/auth/google/callback
# Production: https://yourdomain.com/api/auth/google/callback
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# ==============================================
# EMAIL CONFIGURATION (REQUIRED)
# ==============================================
# Email settings for transactional emails (verification, password reset, welcome)

# SMTP Host (examples below)
# Gmail: smtp.gmail.com
# SendGrid: smtp.sendgrid.net
# AWS SES: email-smtp.us-east-1.amazonaws.com
# Mailgun: smtp.mailgun.org
EMAIL_HOST="smtp.gmail.com"

# SMTP Port
# 587: TLS/STARTTLS (recommended)
# 465: SSL (legacy)
# 25: Unencrypted (not recommended)
EMAIL_PORT="587"

# Use secure connection (SSL/TLS)
# "true" for port 465 (SSL)
# "false" for port 587 (TLS/STARTTLS)
EMAIL_SECURE="false"

# SMTP Authentication Username
# For Gmail: your-email@gmail.com
# For SendGrid: "apikey"
# For AWS SES: your IAM access key ID
EMAIL_USER="your-email@gmail.com"

# SMTP Authentication Password
# For Gmail: Use App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# For SendGrid: Your API key
# For AWS SES: Your IAM secret access key
EMAIL_PASSWORD="your-app-password"

# Email "From" Name (displayed to recipients)
EMAIL_FROM_NAME="Chatter AI"

# Email "From" Address (must be verified in your email provider)
EMAIL_FROM_ADDRESS="your-email@gmail.com"

# ==============================================
# CRON JOB SECURITY (OPTIONAL)
# ==============================================
# Secret token to protect cron endpoints from unauthorized access
# Generate a secure random string (e.g., openssl rand -hex 32)
# Used in: /api/cron/expire-subscriptions
CRON_SECRET=""

# ==============================================
# NOTES
# ==============================================
# 1. For Gmail SMTP:
#    - Enable 2-Step Verification in your Google Account
#    - Generate an App Password at: https://myaccount.google.com/apppasswords
#    - Use the App Password in EMAIL_PASSWORD (not your regular password)
#
# 2. For Production:
#    - Update NEXT_PUBLIC_BASE_URL to your production domain
#    - Update GOOGLE_REDIRECT_URI if using OAuth
#    - Ensure all API keys are production keys, not test keys
#    - Use environment variables in your hosting provider (Vercel, Railway, etc.)
#
# 3. Security:
#    - Never commit .env file to version control
#    - Keep .env in .gitignore
#    - Rotate API keys regularly
#    - Use different keys for development and production
#
# 4. Razorpay Webhooks:
#    - Set up webhook endpoint: https://yourdomain.com/api/webhooks/razorpay
#    - Enable events: payment.captured, payment.failed, subscription.activated, etc.
#    - Copy the webhook secret to RAZORPAY_WEBHOOK_SECRET
